{
  "name": "video-generator-api",
  "version": "1.0.0",
  "description": "API for generating YouTube videos using ElevenLabs, SerpAPI, Pexels, and Remotion",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "dev": "node --watch --require ts-node/register/transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "node --max-old-space-size=4096 ./node_modules/.bin/tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/storage": "^7.9.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@remotion/bundler": "^4.0.286",
    "@remotion/cli": "^4.0.286",
    "@remotion/google-fonts": "^4.0.286",
    "@remotion/renderer": "^4.0.286",
    "@remotion/zod-types": "^4.0.286",
    "axios": "^1.9.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "cuid": "^3.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.0",
    "helmet": "^7.1.0",
    "p-queue": "^7.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.286",
    "swagger-ui-express": "^5.0.0",
    "yaml": "^2.4.2",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
